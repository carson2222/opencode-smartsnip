{
  "name": "opencode-smartsnip",
  "version": "0.1.0",
  "description": "opencode plugin that routes shell commands through the snip token filter — allowlist-driven, shell-aware, configurable",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "bin",
    "commands"
  ],
  "bin": {
    "smartsnip": "bin/smartsnip.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "generate:filters": "bun scripts/generate-filters.ts",
    "prepublishOnly": "bun run typecheck && bun test"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "snip",
    "llm",
    "tokens",
    "context"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carson2222/opencode-smartsnip.git"
  },
  "homepage": "https://github.com/carson2222/opencode-smartsnip#readme",
  "bugs": "https://github.com/carson2222/opencode-smartsnip/issues",
  "author": "Carson (https://github.com/carson2222)",
  "license": "MIT",
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
